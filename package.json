{
  "name": "hitro-api-client",
  "version": "1.0.0",
  "description": "Multi-Protocol API Client — REST, gRPC, GraphQL, WebSocket, Kafka, SQS, MQTT, SSE, Socket.IO",
  "main": "dist/main/index.js",
  "author": "Duck Creek",
  "scripts": {
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev": "npm run build:main && concurrently -k \"npm run dev:renderer\" \"npm run dev:main\" \"wait-on http://localhost:5173 && electron .\"",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:renderer && npm run build:main",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist": "npm run build && electron-builder",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run --coverage",
    "test:e2e": "npm run build && playwright test"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.600.0",
    "@grpc/grpc-js": "^1.11.0",
    "@grpc/proto-loader": "^0.7.13",
    "axios": "^1.7.2",
    "better-sqlite3": "^11.1.2",
    "kafkajs": "^2.2.4",
    "mqtt": "^5.15.1",
    "socket.io-client": "^4.8.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@monaco-editor/react": "^4.6.0",
    "@playwright/test": "^1.45.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.11",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.0.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.2.0",
    "electron-builder": "^24.13.3",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.39",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "vitest": "^2.0.0",
    "wait-on": "^7.2.0",
    "zustand": "^4.5.4"
  },
  "build": {
    "appId": "com.duckcreek.hitro",
    "productName": "Hitro",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "node_modules/**/*", "assets/**/*"],
    "win":   { "target": "nsis",     "icon": "assets/icon.ico" },
    "mac":   { "target": "dmg",      "icon": "assets/icon.icns" },
    "linux": { "target": "AppImage" }
  }
}
